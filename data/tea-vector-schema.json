{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TEA-CODE tea vector schema",
  "version": "0.1.0-alpha",
  "type": "object",
  "required": ["id", "name", "category", "vector", "confidence", "basis", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["green", "white", "yellow", "oolong", "black", "dark", "scented", "powdered", "tisane", "other"]
    },
    "origin": { "type": "string" },
    "cultivar": { "type": "string" },
    "harvest_standard": { "type": "string" },
    "processing_notes": { "type": "string" },
    "vector": {
      "type": "object",
      "required": ["T01", "T02", "P01", "P02", "P03", "P04", "C01", "C02", "C03", "C04", "C05", "C06", "C07", "C08", "S01", "S02"],
      "properties": {
        "T01": { "$ref": "#/$defs/score", "description": "tenderness" },
        "T02": { "$ref": "#/$defs/score", "description": "leaf integrity" },
        "P01": { "$ref": "#/$defs/score", "description": "oxidation degree" },
        "P02": { "$ref": "#/$defs/score", "description": "microbial fermentation degree" },
        "P03": { "$ref": "#/$defs/score", "description": "roast degree" },
        "P04": { "$ref": "#/$defs/score", "description": "aging degree" },
        "C01": { "$ref": "#/$defs/score", "description": "polyphenol intensity" },
        "C02": { "$ref": "#/$defs/score", "description": "catechin retention" },
        "C03": { "$ref": "#/$defs/score", "description": "oxidized polymer intensity" },
        "C04": { "$ref": "#/$defs/score", "description": "free amino acids" },
        "C05": { "$ref": "#/$defs/score", "description": "caffeine" },
        "C06": { "$ref": "#/$defs/score", "description": "aroma volatility" },
        "C07": { "$ref": "#/$defs/score", "description": "water extract" },
        "C08": { "$ref": "#/$defs/score", "description": "mineral ash" },
        "S01": { "$ref": "#/$defs/score", "description": "bitterness and astringency" },
        "S02": { "$ref": "#/$defs/score", "description": "freshness, sweetness, mellowness" }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "basis": {
      "type": "string",
      "enum": ["measured", "literature", "standard", "expert_estimate", "demo_estimate", "mixed"]
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    }
  },
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    }
  },
  "additionalProperties": false
}

